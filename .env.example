# Build-time config for WebRTC signaling (copy to .env.local for Vite).
# Deploy the broker: docker compose up -d
# Put nginx/caddy in front with TLS → wss://signal.yourdomain.ru/peerjs

VITE_PEER_HOST=signal.yourdomain.ru
VITE_PEER_PORT=443
VITE_PEER_PATH=/peerjs
VITE_PEER_SECURE=true

# Auto-join global room on page load (when host above is set):
# VITE_PEER_DEFAULT_MP=true
